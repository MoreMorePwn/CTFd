    {
      "type": "table",
      "id": 19,
      "title": "Containers by name (merged metrics)",
      "description": "Instant snapshot per container name. Use column sort to find outliers.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 17
