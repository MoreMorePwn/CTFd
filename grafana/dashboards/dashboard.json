          "expr": "sum(rate(container_oom_events_total{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\"}[5m])) or vector(0)",
