      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\", cpu=\"total\"}[5m]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (name) (container_memory_working_set_bytes{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\"})",
