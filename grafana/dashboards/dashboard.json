        {
          "expr": "sum(sum by (name) (container_memory_working_set_bytes{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\"}))",
