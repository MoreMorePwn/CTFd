{
  "uid": "containers-fleet-cadvisor",
  "title": "Container fleet (cAdvisor)",
  "description": "High-cardinality friendly overview: filter by job, scrape instance, Compose stack, and container name. Focuses on named workloads with an image label (excludes host/systemd cgroups without images).",
  "timezone": "browser",
  "schemaVersion": 42,
  "version": 5,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ]
  },
  "editable": true,
  "tags": [
    "prometheus",
    "cadvisor",
    "containers",
    "docker"
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {
          "selected": true,
          "text": "prometheus",
          "value": "prometheus"
        }
      },
      {
        "name": "job",
        "type": "query",
        "label": "Scrape job",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(container_last_seen, job)",
        "query": {
          "query": "label_values(container_last_seen, job)",
          "refId": "PromJob"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "instance",
        "type": "query",
        "label": "cAdvisor instance",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(container_last_seen{job=~\"$job\"}, instance)",
        "query": {
          "query": "label_values(container_last_seen{job=~\"$job\"}, instance)",
          "refId": "PromInst"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "stack",
        "type": "query",
        "label": "Compose stack",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(container_last_seen{job=~\"$job\", instance=~\"$instance\", name!=\"\", image!=\"\"}, container_label_com_docker_compose_project)",
        "query": {
          "query": "label_values(container_last_seen{job=~\"$job\", instance=~\"$instance\", name!=\"\", image!=\"\"}, container_label_com_docker_compose_project)",
          "refId": "PromStack"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      },
      {
        "name": "container",
        "type": "query",
        "label": "Container name",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(container_last_seen{job=~\"$job\", instance=~\"$instance\", container_label_com_docker_compose_project=~\"$stack\", name!=\"\", image!=\"\"}, name)",
        "query": {
          "query": "label_values(container_last_seen{job=~\"$job\", instance=~\"$instance\", container_label_com_docker_compose_project=~\"$stack\", name!=\"\", image!=\"\"}, name)",
          "refId": "PromCont"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "At a glance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Running containers",
      "description": "Count of distinct container names with an image (Docker-style workloads).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "count(count by (name) (container_last_seen{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\"}))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Stale (no scrape 5m)",
      "description": "Containers whose last seen timestamp is older than 5 minutes (within current filters).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "expr": "count((time() - container_last_seen{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\"}) > 300) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Fleet CPU",
      "description": "Sum of per-container CPU usage (cores) after filters.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(sum by (name) (rate(container_cpu_usage_seconds_total{job=~\"$job\", instance=~\"$instance\", name=~\"$container\", name!=\"\", image!=\"\", container_label_com_docker_compose_project=~\"$stack\", cpu=\"total\"}[5m])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Fleet memory (working set)",
