apiVersion: 1

deleteDatasources:
  - name: prometheus-1
    orgId: 1

datasources:
  - name: prometheus
    uid: prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: true
    editable: true
    basicAuth: true
    basicAuthUser: ${PROMETHEUS_BASIC_USER}
    secureJsonData:
      basicAuthPassword: ${PROMETHEUS_BASIC_PASSWORD}
